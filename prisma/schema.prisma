generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  name                String
  emailVerified       Boolean            @default(false)
  image               String?
  passwordHash        String?
  avatar              String?
  role                Role               @default(USER)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  accounts            Account[]
  approvalRequests    ApprovalRequest[]
  bans                BanList[]
  events              Event[]            @relation("EventOrganizer")
  participations      EventParticipant[]
  invitationsReceived Invitation[]       @relation("Invitee")
  invitationsSent     Invitation[]       @relation("Inviter")
  notifications       Notification[]
  payments            Payment[]
  reviews             Review[]
  sessions            Session[]
}

model EventCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]
}

model Event {
  id               String             @id @default(uuid())
  title            String
  description      String
  bannerImage      String?
  date             DateTime
  venue            String?
  eventLink        String?
  fee              Float              @default(0.0)
  eventType        EventType
  isFeatured       Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  organizerId      String
  categoryId       String
  approvalRequests ApprovalRequest[]
  bans             BanList[]
  category         EventCategory      @relation(fields: [categoryId], references: [id])
  organizer        User               @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  participants     EventParticipant[]
  invitations      Invitation[]
  payments         Payment[]
  reviews          Review[]
  tags             String?
}

model EventParticipant {
  id       String            @id @default(uuid())
  status   ParticipantStatus @default(PENDING)
  joinedAt DateTime          @default(now())
  userId   String
  eventId  String
  event    Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Invitation {
  id        String            @id @default(uuid())
  status    ParticipantStatus @default(PENDING)
  createdAt DateTime          @default(now())
  eventId   String
  inviterId String
  inviteeId String
  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitee   User              @relation("Invitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  inviter   User              @relation("Inviter", fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([eventId, inviteeId])
}

model Payment {
  id              String        @id @default(uuid())
  amount          Float
  stripeSessionId String?       @unique
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userId          String
  eventId         String
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApprovalRequest {
  id        String            @id @default(uuid())
  status    ParticipantStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  userId    String
  eventId   String
  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model BanList {
  id        String   @id @default(uuid())
  reason    String?
  createdAt DateTime @default(now())
  userId    String
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

enum Role {
  USER
  ORGANIZER
  ADMIN
}

enum EventType {
  PUBLIC_FREE
  PUBLIC_PAID
  PRIVATE_FREE
  PRIVATE_PAID
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ParticipantStatus {
  PENDING
  APPROVED
  REJECTED
  BANNED
}
